# ===== AIVideoCreator 環境変数 =====
# いずれも未設定の場合、対応する API Routes は自動的にモック応答を返す。
# （= キー無しでもアプリは完全に動作する。実APIを使うときだけ設定する）

# --- フロントエンドのAPIモード ---
# "server" : /api/* を呼ぶ（バックエンド利用）。デフォルト。
# "mock"   : サーバーを介さずクライアント内モックで動かす（静的配信向け）。
NEXT_PUBLIC_API_MODE=server

# --- 音声合成 (ElevenLabs) ---
# https://elevenlabs.io/ のAPIキー。未設定ならモック音声URLを返す。
ELEVENLABS_API_KEY=
# 使用するボイスID（未設定なら ElevenLabs のデフォルト）。
ELEVENLABS_VOICE_ID=

# --- 動画生成: ローカル ComfyUI (任意・無料) ---
# 設定すると RunWay の代わりにローカルの ComfyUI で動画を生成できる。
# アプリと ComfyUI を同じPCで起動すること（サーバー側から接続するため）。
# 設定画面の「動画生成プロバイダ」で ComfyUI を選び、URLとワークフローを
# 入力する運用が基本。env で常用する場合は下記を設定:
COMFYUI_BASE_URL=
# ワークフロー(API形式JSON)。長い場合は設定画面での入力を推奨。
# COMFYUI_WORKFLOW=
COMFYUI_POLL_INTERVAL_MS=2000
COMFYUI_POLL_TIMEOUT_MS=600000

# --- 動画生成 (RunWay) ---
# 未設定ならモック動画クリップを返す。
RUNWAY_API_KEY=
# image_to_video は起点画像が必須。全シーン共通の既定画像URL（任意。
# 指定が無くリクエストにも画像が無い場合は生成エラーになる）。
RUNWAY_DEFAULT_IMAGE=
# ポーリング設定（任意）。間隔と全体タイムアウト（ミリ秒）。
RUNWAY_POLL_INTERVAL_MS=5000
RUNWAY_POLL_TIMEOUT_MS=300000
# エンドポイント差し替え（任意。テスト/モック用）。
# RUNWAY_API_BASE=https://api.dev.runwayml.com/v1
# RUNWAY_API_VERSION=2024-11-06

# --- 台本のシーン分割をLLMで行う場合 (任意) ---
# 未設定ならヒューリスティック分割にフォールバックする。
ANTHROPIC_API_KEY=

# --- Supabase (認証 / DB / Storage・RLS) ---
# 両方を設定すると、ログイン・プロジェクトのクラウド保存・メディアのStorage保存が
# 有効になる。未設定なら従来どおり localStorage / data URL で動作する。
# Supabase ダッシュボード → Project Settings → API から取得。
# 初回はリポジトリ同梱の supabase/schema.sql を SQL Editor で実行すること。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
